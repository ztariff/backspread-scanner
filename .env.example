# Polygon.io API key (required)
POLYGON_API_KEY=your_polygon_api_key_here

# Optional overrides (uncomment to use)
# POLYGON_RATE_LIMIT=0.25

# Long leg (far OTM, longer expiry)
# DIAG_LONG_MIN_DTE=14
# DIAG_LONG_MAX_DTE=120
# DIAG_LONG_MIN_OTM_PCT=0.05
# DIAG_LONG_MAX_OTM_PCT=0.40
# DIAG_LONG_MAX_PRICE=5.00
# DIAG_LONG_MAX_DELTA=0.20

# Short leg (ATM-ish, shorter expiry)
# DIAG_SHORT_MIN_DTE=1
# DIAG_SHORT_MAX_DTE=14
# DIAG_SHORT_MIN_DELTA=0.25
# DIAG_SHORT_MAX_DELTA=0.60

# Cheapness thresholds
# DIAG_MIN_EQUIDIST_RATIO=2.0
# DIAG_MAX_IV_RV_RATIO=1.0
# DIAG_MAX_CHEAP_PRICE=2.00
# DIAG_PREMIUM_NEUTRAL_TOL=0.20

# Other
# DIAG_RISK_FREE_RATE=0.045
# DIAG_TOP_N=25
